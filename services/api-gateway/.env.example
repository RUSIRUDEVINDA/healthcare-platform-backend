PORT=8000
APP_ENV=development

# Required defaults match docker-compose service names (team-guide ports).
AUTH_SERVICE_URL=http://auth-service:8001
DOCTOR_SERVICE_URL=http://doctor-service:8003
AI_SYMPTOM_SERVICE_URL=http://ai-symptom-service:8008

